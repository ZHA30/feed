{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "translate": {
      "type": "object",
      "properties": {
        "systemPrompt": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "systemPrompt"
      ]
    },
    "summary": {
      "type": "object",
      "properties": {
        "systemPrompt": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "systemPrompt"
      ]
    },
    "feeds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "default": 25,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "translate": {
            "type": "object",
            "properties": {
              "targetLanguage": {
                "type": "string",
                "minLength": 1
              },
              "mode": {
                "default": "bilingual",
                "type": "string",
                "enum": [
                  "translation",
                  "bilingual"
                ]
              },
              "fields": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "title",
                    "description",
                    "content:encoded",
                    "summary",
                    "content"
                  ]
                }
              }
            },
            "required": [
              "targetLanguage",
              "fields"
            ]
          },
          "summary": {
            "type": "object",
            "properties": {
              "sourceField": {
                "type": "string",
                "enum": [
                  "title",
                  "description",
                  "content:encoded",
                  "summary",
                  "content"
                ]
              },
              "prompt": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "sourceField",
              "prompt"
            ]
          }
        },
        "required": [
          "path",
          "url"
        ]
      }
    }
  },
  "required": [
    "feeds"
  ],
  "$id": "feeds.schema.json",
  "title": "Feed configuration",
  "description": "Configuration for feed feature generation."
}
